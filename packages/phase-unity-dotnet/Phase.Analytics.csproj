<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <RootNamespace>Phase.Analytics</RootNamespace>
    <AssemblyName>Phase.Analytics</AssemblyName>
    <DefineConstants>UNITY_5_3_OR_NEWER</DefineConstants>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../phase-unity/Runtime/**/*.cs" Exclude="../phase-unity/Runtime/PhaseAnalyticsEditorReset.cs" />
    <Compile Include="UnityShims/**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Phase.Analytics.Tests" />
  </ItemGroup>
</Project>
