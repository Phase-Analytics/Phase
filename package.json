{
  "name": "phase",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/sdk",
    "packages/shared"
  ],
  "scripts": {
    "dev": "bun run dev:server & bun run dev:web",
    "dev:server": "bun run --filter server dev",
    "dev:web": "bun run --filter web dev",
    "dev:mobile": "bun run --filter mobile dev",
    "ios": "bun --filter mobile ios",
    "android": "bun --filter mobile android",
    "ios:sim": "bun --filter mobile ios:sim",
    "android:sim": "bun --filter mobile android:sim",
    "ios:release": "bun --filter mobile ios:release",
    "android:release": "bun --filter mobile android:release",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun run --filter './packages/sdk' --filter './packages/shared' build",
    "build:apps": "bun run --filter './apps/*' build",
    "build:server": "bun run --filter server build",
    "build:web": "bun run --filter web build",
    "db:studio": "bun run --filter server db:studio",
    "db:generate": "bun run --filter server db:generate",
    "db:migrate": "bun run --filter server db:migrate",
    "db:push": "bun run --filter server db:push",
    "check": "bunx ultracite fix --unsafe",
    "typecheck": "bun run --filter './apps/*' --filter './packages/sdk' --filter './packages/shared' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "typescript": "^5",
    "ultracite": "5.6.1"
  },
  "overrides": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "csstype": "3.1.3"
  },
  "packageManager": "bun@1.3.3"
}
